ft click\n                x, y = event.pos\n                grid_x, grid_y = self.grid.screen_to_grid(x, y)\n                building_type = self.get_selected_building_type()\n                if building_type:\n                    building = Building(x=grid_x, y=grid_y, type=building_type)\n                    if self.grid.place_building(building):\n                        print(f"Placed {building_type} at ({grid_x}, {grid_y})")\n                    else:\n                        print("Invalid placement")\n\n    def get_selected_building_type(self) -> Optional[str]:\n        """\n        Determines the currently selected building type.\n        This is a placeholder for the actual implementation of building selection.\n        """\n        # Example: Always return \'House\'. Replace with real menu logic.\n        return "House"'}
