2026-01-01 00:40:09,228 - MetaFlow.llm.client - INFO - Execute tool write_file with args: {'path': 'core/grid.py', 'content': 'from typing import List, Optional\nfrom core.buildings import Building\n\nclass Grid:\n    """\n    Class to manage the 2D grid of buildings in the city simulation.\n    """\n\n    def __init__(self, width: int, height: int):\n        """\n        Initializes the grid with the given dimensions.\n\n        :param width: Number of columns in the grid.\n        :param height: Number of rows in the grid.\n        """\n        self.cells: List[List[Optional[Building]]] = [[None for _ in range(width)] for _ in range(height)]\n\n    def place_building(self, building: Building) -> bool:\n        """\n        Places a building on the grid if the cell is empty.\n\n        :param building: The building to place on the grid.\n        :return: True if the building was successfully placed, False otherwise.\n        """\n        x, y = building.x, building.y\n\n        # Validate grid boundaries\n        if not (0 <= x < len(self.cells[0]) and 0 <= y < len(self.cells)):\n            return False\n\n        # Check if the cell is empty\n        if self.cells[y][x] is not None:\n            return False\n\n        # Additional adjacency validation for specific building types (e.g., Roads)\n        if building.type == "Road":\n            if not self._has_adjacent_building(x, y):\n                return False\n\n        # Place the building\n        self.cells[y][x] = building\n        return True\n\n    def _has_adjacent_building(self, x: int, y: int) -> bool:\n        """\n        Checks if the specified cell has any adjacent buildings.\n\n        :param x: X-coordinate of the cell.\n        :param y: Y-coordinate of the cell.\n        :return: True if there is at least one adjacent building, False otherwise.\n        """\n        directions = [(-1, 0), (1, 0), (0, -1), (0, 1)]\n\n        for dx, dy in directions:\n            nx, ny = x + dx, y + dy\n\n            if 0 <= nx < len(self.cells[0]) and 0 <= ny < len(self.cells):\n                if self.cells[ny][nx] is not None:\n                    return True\n\n        return False'}
