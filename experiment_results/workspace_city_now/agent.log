  "code": "from typing import List, Optional\nfrom core.buildings import Building\n\nclass Grid:\n    def __init__(self, width: int, height: int):\n        \"\"\"\n        Initializes the grid with the given width and height.\n\n        :param width: Number of columns in the grid.\n        :param height: Number of rows in the grid.\n        \"\"\"\n        self.cells: List[List[Optional[Building]]] = [[None for _ in range(width)] for _ in range(height)]\n\n    def place_building(self, building: Building) -> bool:\n        \"\"\"\n        Places a building on the grid if the cell is empty and validates adjacency rules for certain building types.\n\n        :param building: The building to be placed.\n        :return: True if the building was successfully placed, False otherwise.\n        \"\"\"\n        x, y = building.x, building.y\n\n        # Check if the coordinates are within the grid bounds\n        if x < 0 or y < 0 or x >= len(self.cells[0]) or y >= len(self.cells):\n            return False\n\n        # Check if the cell is already occupied\n        if self.cells[y][x] is not None:\n            return False\n\n        # Additional adjacency rules for Roads\n        if building.type == \"Road\":\n            if not self._has_adjacent_road(x, y):\n                return False\n\n        # Place the building\n        self.cells[y][x] = building\n        return True\n\n    def _has_adjacent_road(self, x: int, y: int) -> bool:\n        \"\"\"\n        Checks if the given cell has any adjacent Roads.\n\n        :param x: X-coordinate of the cell.\n        :param y: Y-coordinate of the cell.\n        :return: True if at least one adjacent cell contains a Road, False otherwise.\n        \"\"\"\n        directions = [(-1, 0), (1, 0), (0, -1), (0, 1)]  # Up, Down, Left, Right\n        for dx, dy in directions:\n            nx, ny = x + dx, y + dy\n            if 0 <= nx < len(self.cells[0]) and 0 <= ny < len(self.cells):\n                adjacent_building = self.cells[ny][nx]\n                if adjacent_building and adjacent_building.type == \"Road\":\n                    return True\n        return False"
}
