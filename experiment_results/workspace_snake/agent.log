        "type": "write_file",
        "content": "import pygame\nfrom typing import List, Tuple\n\nclass Snake:\n    def __init__(self, initial_position: Tuple[int, int], initial_speed: float):\n        \"\"\"Initialize the snake with its starting position and speed.\"\"\"\n        self.body: List[Tuple[int, int]] = [initial_position]\n        self.direction: Tuple[int, int] = (0, 1)  # Default direction: moving down\n        self.speed: float = initial_speed\n\n    def move(self) -> None:\n        \"\"\"Updates the snake's position based on its direction and speed.\"\"\"\n        head_x, head_y = self.body[0]\n        delta_x, delta_y = self.direction\n\n        # Calculate new head position\n        new_head = (head_x + delta_x * self.speed, head_y + delta_y * self.speed)\n\n        # Update body positions\n        self.body = [new_head] + self.body[:-1]\n\n    def grow(self) -> None:\n        \"\"\"Increases the length of the snake by one segment.\"\"\"\n        # Add new segment at the tail's position\n        tail_x, tail_y = self.body[-1]\n        self.body.append((tail_x, tail_y))\n\n    def check_collision(self, walls: List[Tuple[int, int]]) -> bool:\n        \"\"\"Checks if the snake has collided with itself or the walls.\"\"\"\n        head = self.body[0]\n\n        # Check collision with itself\n        if head in self.body[1:]:\n            return True\n\n        # Check collision with walls\n        if head in walls:\n            return True\n\n        return False\n\n    def apply_effect(self, effect: 'EffectInterface') -> None:\n        \"\"\"Applies the effect of a power-up to the snake.\"\"\"\n        effect.apply(self)",
