2025-12-31 21:26:36,343 - MetaFlow.llm.client - INFO - Execute tool write_file with args: {'path': 'core/snake.py', 'content': 'from typing import List, Tuple\nfrom .effect_interface import EffectInterface\n\nclass Snake:\n    def __init__(self, initial_body: List[Tuple[int, int]], initial_direction: Tuple[int, int], speed: float):\n        """\n        Initializes the snake with its initial body, direction, and speed.\n\n        :param initial_body: List of tuples representing the initial coordinates of the snake\'s body.\n        :param initial_direction: Tuple representing the initial direction of the snake.\n        :param speed: Float representing the snake\'s movement speed.\n        """\n        self.body = initial_body\n        self.direction = initial_direction\n        self.speed = speed\n\n    def move(self) -> None:\n        """\n        Updates the snake\'s position based on its current direction and speed.\n        """\n        head_x, head_y = self.body[0]\n        new_head = (head_x + self.direction[0], head_y + self.direction[1])\n        self.body.insert(0, new_head)  # Add new head to the front of the body\n        self.body.pop()  # Remove the last segment to simulate movement\n\n    def grow(self) -> None:\n        """\n        Increases the length of the snake by one segment.\n        """\n        tail_x, tail_y = self.body[-1]\n        self.body.append((tail_x, tail_y))\n\n    def check_collision(self, walls: List[Tuple[int, int]]) -> bool:\n        """\n        Checks if the snake has collided with itself or the walls.\n\n        :param walls: List of tuples representing wall coordinates.\n        :return: Boolean indicating whether a collision occurred.\n        """\n        head = self.body[0]\n\n        # Check collision with self\n        if head in self.body[1:]:\n            return True\n\n        # Check collision with walls\n        if head in walls:\n            return True\n\n        return False\n\n    def apply_effect(self, effect: EffectInterface) -> None:\n        """\n        Applies the effect of a power-up to the snake.\n\n        :param effect: An instance of EffectInterface representing the power-up effect.\n        """\n        effect.apply(self)'}
