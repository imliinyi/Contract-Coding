2025-12-31 21:22:29,583 - MetaFlow.llm.client - INFO - Execute tool write_file with args: {'path': 'main.py', 'content': 'import pygame\nimport sys\nfrom core.snake import Snake\nfrom core.movement import Movement\nfrom core.map_loader import MapLoader\nfrom core.powerups.powerup_factory import PowerUpFactory\nfrom save_system.save_manager import SaveManager\nfrom core.ui_manager import UIManager\nfrom config import SNAKE_INITIAL_SPEED, POWERUP_SPAWN_INTERVAL, MAP_DIRECTORY, SAVE_FILE_PATH\n\ndef main() -> None:\n    """\n    Entry point for the game. Initializes components, starts the game loop,\n    and manages interactions between systems.\n    """\n    # Initialize Pygame\n    pygame.init()\n\n    # Screen settings\n    screen = pygame.display.set_mode((800, 600))\n    pygame.display.set_caption("Snake Grand-Master")\n    clock = pygame.time.Clock()\n\n    # Initialize game components\n    snake = Snake(speed=SNAKE_INITIAL_SPEED)\n    movement = Movement()\n    map_loader = MapLoader(MAP_DIRECTORY)\n    power_up_factory = PowerUpFactory()\n    save_manager = SaveManager(SAVE_FILE_PATH)\n    ui_manager = UIManager()\n\n    # Load initial map\n    walls = map_loader.load_map("box_map")\n\n    # Game state variables\n    running = True\n    score = 0\n    powerups = []\n    last_powerup_spawn_time = pygame.time.get_ticks()\n\n    while running:\n        # Event handling\n        for event in pygame.event.get():\n            if event.type == pygame.QUIT:\n                running = False\n\n            if event.type == pygame.KEYDOWN:\n                if event.key == pygame.K_UP:\n                    snake.direction = movement.change_direction(snake.direction, (0, -1))\n                elif event.key == pygame.K_DOWN:\n                    snake.direction = movement.change_direction(snake.direction, (0, 1))\n                elif event.key == pygame.K_LEFT:\n                    snake.direction = movement.change_direction(snake.direction, (-1, 0))\n                elif event.key == pygame.K_RIGHT:\n                    snake.direction = movement.change_direction(snake.direction, (1, 0))\n\n        # Update game state\n        snake.move()\n\n        # Check for collisions\n        if snake.check_collision(walls):\n            running = False\n\n        # Check for power-up effects\n        for powerup in powerups:\n            if snake.body[0] == powerup.position:  # Assuming powerups have a position attribute\n                powerup.apply(snake)\n                score += 10\n                powerups.remove(powerup)\n\n        # Spawn power-ups\n        current_time = pygame.time.get_ticks()\n        if current_time - last_powerup_spawn_time > POWERUP_SPAWN_INTERVAL * 1000:\n            powerups.append(power_up_factory.create_powerup("Apple"))  # Example power-up type\n            last_powerup_spawn_time = current_time\n\n        # Render game state\n        ui_manager.render_game_state(screen, snake, powerups, walls, score)\n\n        # Update screen\n        pygame.display.flip()\n        clock.tick(10)\n\n    # Save score and display leaderboard\n    player_name = input("Enter your name: ")\n    save_manager.save_score(player_name, score)\n    leaderboard = save_manager.load_leaderboard()\n    ui_manager.render_leaderboard(screen, leaderboard)\n\n    # Quit Pygame\n    pygame.quit()\n    sys.exit()\n\nif __name__ == "__main__":\n    main()'}
