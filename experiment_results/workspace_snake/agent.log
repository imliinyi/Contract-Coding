2025-12-31 21:26:47,288 - MetaFlow.llm.client - INFO - Execute tool write_file with args: {'path': 'main.py', 'content': 'import pygame\nimport sys\nfrom core.snake import Snake\nfrom core.map_loader import MapLoader\nfrom save_system.save_manager import SaveManager\nfrom core.powerups.powerup_factory import PowerUpFactory\nfrom core.ui_manager import UIManager\nimport config\nimport time\n\n\ndef main():\n    """\n    Entry point for the game. Initializes components, starts the game loop,\n    and manages interactions between systems.\n    """\n    pygame.init()\n\n    # Initialize the game window\n    screen_width = 800\n    screen_height = 600\n    screen = pygame.display.set_mode((screen_width, screen_height))\n    pygame.display.set_caption("Snake Grand-Master")\n\n    clock = pygame.time.Clock()\n\n    # Initialize components\n    snake = Snake([(5, 5)], (0, 1), config.SNAKE_INITIAL_SPEED)\n    map_loader = MapLoader()\n    walls = map_loader.load_map("box_map.json")  # Load the default map\n    save_manager = SaveManager()\n    powerup_factory = PowerUpFactory()\n    ui_manager = UIManager(screen_width, screen_height)\n\n    # Game variables\n    running = True\n    score = 0\n    powerups = []\n    last_spawn_time = time.time()\n\n    # Game loop\n    while running:\n        for event in pygame.event.get():\n            if event.type == pygame.QUIT:\n                running = False\n\n        # Handle user input\n        keys = pygame.key.get_pressed()\n        if keys[pygame.K_UP]:\n            snake.direction = (0, -1)\n        elif keys[pygame.K_DOWN]:\n            snake.direction = (0, 1)\n        elif keys[pygame.K_LEFT]:\n            snake.direction = (-1, 0)\n        elif keys[pygame.K_RIGHT]:\n            snake.direction = (1, 0)\n\n        # Update game state\n        snake.move()\n\n        # Check for collisions\n        if snake.check_collision(walls):\n            print("Game Over! Collision detected.")\n            running = False\n\n        # Spawn power-ups periodically\n        if time.time() - last_spawn_time > config.POWERUP_SPAWN_INTERVAL:\n            powerups.append(powerup_factory.create_powerup("Apple"))\n            last_spawn_time = time.time()\n\n        # Check for power-up collection\n        for powerup in powerups:\n            if snake.body[0] == powerup.position:  # If snake\'s head is on power-up\n                powerup.apply(snake)\n                score += 10  # Increment score for collecting power-ups\n                powerups.remove(powerup)\n\n        # Render the game state\n        screen.fill((0, 0, 0))  # Clear the screen with black color\n        ui_manager.render_game_state(snake, powerups, walls, score)\n        pygame.display.flip()\n\n        clock.tick(10)  # Cap the frame rate to 10 FPS\n\n    # Save score and update leaderboard\n    player_name = input("Enter your name: ")\n    save_manager.save_score(player_name, score)\n    leaderboard = save_manager.load_leaderboard()\n\n    # Render leaderboard\n    screen.fill((0, 0, 0))\n    ui_manager.render_leaderboard(leaderboard)\n    pygame.display.flip()\n\n    pygame.time.wait(5000)  # Display leaderboard for 5 seconds before exiting\n\n    pygame.quit()\n    sys.exit()\n\nif __name__ == "__main__":\n    main()'}
