2025-12-31 21:28:04,496 - MetaFlow.llm.client - INFO - Execute tool write_file with args: {'content': 'from typing import List, Tuple\nfrom core.effect_interface import EffectInterface\n\nclass Snake:\n    def __init__(self, initial_body: List[Tuple[int, int]], initial_direction: Tuple[int, int], initial_speed: float):\n        """\n        Initializes a Snake object.\n\n        :param initial_body: List of coordinates representing the snake\'s body.\n        :param initial_direction: Tuple representing the initial direction (dx, dy).\n        :param initial_speed: Initial speed of the snake.\n        """\n        self.body = initial_body\n        self.direction = initial_direction\n        self.speed = initial_speed\n\n    def move(self) -> None:\n        """\n        Updates the snake\'s position based on its direction and speed.\n        """\n        # Calculate new head position\n        head_x, head_y = self.body[0]\n        new_head = (head_x + self.direction[0], head_y + self.direction[1])\n\n        # Move the snake\n        self.body = [new_head] + self.body[:-1]\n\n    def grow(self) -> None:\n        """\n        Increases the length of the snake by one segment.\n        """\n        tail_x, tail_y = self.body[-1]\n        # Add a new segment to the tail\n        self.body.append((tail_x, tail_y))\n\n    def check_collision(self, walls: List[Tuple[int, int]]) -> bool:\n        """\n        Checks if the snake has collided with itself or the walls.\n\n        :param walls: List of coordinates representing wall positions.\n        :return: True if there\'s a collision, False otherwise.\n        """\n        head = self.body[0]\n        # Check collision with walls\n        if head in walls:\n            return True\n\n        # Check collision with itself\n        if head in self.body[1:]:\n            return True\n\n        return False\n\n    def apply_effect(self, effect: EffectInterface) -> None:\n        """\n        Applies the effect of a power-up to the snake.\n\n        :param effect: Instance of EffectInterface to apply.\n        """\n        effect.apply(self)', 'path': 'core/snake.py'}
