        "content": "import json\nimport os\nfrom typing import List, Tuple\nfrom config import MAP_DIRECTORY\n\nclass MapLoader:\n    def load_map(self, map_name: str) -> List[Tuple[int, int]]:\n        \"\"\"\n        Loads the specified map configuration and returns wall coordinates.\n\n        :param map_name: Name of the map file (e.g., 'box_map.json').\n        :return: List of wall coordinates as (x, y) tuples.\n        :raises FileNotFoundError: If the file does not exist.\n        :raises ValueError: If the map file is invalid or missing required attributes.\n        \"\"\"\n        file_path = os.path.join(MAP_DIRECTORY, map_name)\n\n        try:\n            with open(file_path, 'r') as f:\n                map_data = json.load(f)\n        except FileNotFoundError:\n            raise FileNotFoundError(f\"Map file '{map_name}' not found in directory '{MAP_DIRECTORY}'.\")\n        except json.JSONDecodeError:\n            raise ValueError(f\"Map file '{map_name}' contains invalid JSON.\")\n\n        # Validate and extract walls attribute\n        if 'walls' not in map_data or not isinstance(map_data['walls'], list):\n            raise ValueError(f\"Map file '{map_name}' is missing 'walls' or it is not a list.\")\n\n        # Ensure all wall coordinates are valid tuples\n        try:\n            walls = [tuple(coord) for coord in map_data['walls']]\n        except TypeError:\n            raise ValueError(f\"Wall coordinates in map file '{map_name}' are malformed.\")\n\n        return walls"
    }
}
