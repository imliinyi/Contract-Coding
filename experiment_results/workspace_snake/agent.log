2025-12-31 21:25:16,079 - MetaFlow.llm.client - INFO - Execute tool write_file with args: {'path': 'main.py', 'content': 'import pygame\nimport sys\nimport random\nfrom config import SNAKE_INITIAL_SPEED, POWERUP_SPAWN_INTERVAL, MAP_DIRECTORY, SAVE_FILE_PATH\nfrom core.snake import Snake\nfrom core.movement import Movement\nfrom core.ui_manager import UIManager\nfrom core.map_loader import MapLoader\nfrom save_system.save_manager import SaveManager\nfrom core.powerups.powerup_factory import PowerUpFactory\nfrom core.effect_interface import EffectInterface\n\ndef main() -> None:\n    """\n    Entry point for the game. Initializes components, starts the game loop,\n    and manages interactions between systems.\n    """\n    pygame.init()\n\n    # Screen dimensions\n    SCREEN_WIDTH = 800\n    SCREEN_HEIGHT = 600\n    screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))\n    clock = pygame.time.Clock()\n\n    # Initialize game components\n    snake = Snake()\n    movement = Movement()\n    ui_manager = UIManager(SCREEN_WIDTH, SCREEN_HEIGHT)\n    map_loader = MapLoader(MAP_DIRECTORY)\n    save_manager = SaveManager(SAVE_FILE_PATH)\n    powerup_factory = PowerUpFactory()\n\n    # Load map\n    current_map_name = "box_map.json"  # Default map\n    walls = map_loader.load_map(current_map_name)\n\n    # Power-ups and spawn timer\n    powerups = []\n    powerup_timer = 0\n\n    # Game state\n    running = True\n    score = 0\n\n    while running:\n        screen.fill((0, 0, 0))  # Clear screen with black\n\n        for event in pygame.event.get():\n            if event.type == pygame.QUIT:\n                running = False\n\n            # Handle user input for snake direction\n            if event.type == pygame.KEYDOWN:\n                if event.key == pygame.K_UP:\n                    snake.direction = movement.change_direction(snake.direction, (0, -1))\n                elif event.key == pygame.K_DOWN:\n                    snake.direction = movement.change_direction(snake.direction, (0, 1))\n                elif event.key == pygame.K_LEFT:\n                    snake.direction = movement.change_direction(snake.direction, (-1, 0))\n                elif event.key == pygame.K_RIGHT:\n                    snake.direction = movement.change_direction(snake.direction, (1, 0))\n\n        # Move the snake\n        snake.move()\n\n        # Check for collisions\n        if snake.check_collision(walls) or snake.check_collision(snake.body[1:]):\n            running = False  # End game if collision occurs\n\n        # Check for power-up collisions and apply effects\n        for powerup in powerups[:]:\n            if snake.body[0] == powerup.position:  # Head of snake collides with power-up\n                powerup.apply(snake)\n                powerups.remove(powerup)\n\n        # Spawn power-ups at regular intervals\n        powerup_timer += 1\n        if powerup_timer >= POWERUP_SPAWN_INTERVAL:\n            powerup_type = random.choice(["Apple", "Magnet", "Shield"])\n            powerup = powerup_factory.create_powerup(powerup_type)\n            spawn_position = random.choice(walls.get("powerup_spawns", []))\n            powerup.position = spawn_position\n            powerups.append(powerup)\n            powerup_timer = 0\n\n        # Render game state\n        ui_manager.render_game_state(snake, powerups, walls, score)\n\n        # Update screen\n        pygame.display.flip()\n\n        # Cap the frame rate\n        clock.tick(SNAKE_INITIAL_SPEED)\n\n    # Save score and update leaderboard\n    player_name = input("Enter your name: ")\n    save_manager.save_score(player_name, score)\n    leaderboard = save_manager.load_leaderboard()\n    ui_manager.render_leaderboard(leaderboard)\n\n    pygame.quit()\n    sys.exit()\n\nif __name__ == "__main__":\n    main()'}
