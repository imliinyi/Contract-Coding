2025-12-31 21:29:13,770 - MetaFlow.llm.client - INFO - Execute tool write_file with args: {'content': 'from typing import List, Tuple\nfrom core.effect_interface import EffectInterface\n\nclass Snake:\n    def __init__(self, initial_body: List[Tuple[int, int]], initial_direction: Tuple[int, int], speed: float):\n        """\n        Initializes the snake with a body, direction, and speed.\n\n        :param initial_body: List of tuples representing the initial body segments of the snake.\n        :param initial_direction: Tuple representing the initial direction of the snake.\n        :param speed: The movement speed of the snake.\n        """\n        self.body = initial_body\n        self.direction = initial_direction\n        self.speed = speed\n\n    def move(self) -> None:\n        """\n        Updates the snake\'s position based on its direction and speed.\n        """\n        if not self.body:\n            return\n\n        # Calculate new head position based on direction\n        head_x, head_y = self.body[0]\n        delta_x, delta_y = self.direction\n        new_head = (head_x + delta_x, head_y + delta_y)\n\n        # Update the body by adding the new head and removing the tail\n        self.body = [new_head] + self.body[:-1]\n\n    def grow(self) -> None:\n        """\n        Increases the length of the snake by one segment.\n        """\n        if self.body:\n            # Add a new segment at the position of the last segment\n            self.body.append(self.body[-1])\n\n    def check_collision(self, walls: List[Tuple[int, int]]) -> bool:\n        """\n        Checks if the snake has collided with itself or the walls.\n\n        :param walls: List of tuples representing wall coordinates.\n        :return: True if there is a collision, False otherwise.\n        """\n        if not self.body:\n            return False\n\n        # Get the head of the snake\n        head = self.body[0]\n\n        # Check collision with walls\n        if head in walls:\n            return True\n\n        # Check collision with itself (excluding the head)\n        if head in self.body[1:]:\n            return True\n\n        return False\n\n    def apply_effect(self, effect: EffectInterface) -> None:\n        """\n        Applies the effect of a power-up to the snake.\n\n        :param effect: An instance of EffectInterface.\n        """\n        effect.apply(self)', 'path': 'core/snake.py'}
